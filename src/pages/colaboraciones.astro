---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Viriato - Colaboraciones"
  description="Colaboraciones desde campo real, living lab y producto digital con foco en transferencia."
>
  <section class="hero-page">
    <div class="container">
      <div class="eyebrow">Colaboraciones</div>
      <h1>Colaborar para validar y transferir soluciones en campo real</h1>
      <p class="subtitle">
        Viriato está abierto a universidades, centros de investigación,
        administraciones y aliados tecnológicos que quieran trabajar con una
        arquitectura poco habitual: explotación real, living lab y producto
        digital en el mismo sistema.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Con quién nos interesa colaborar</h2>
      <p class="mt-2">
        Con equipos que necesiten validar, transferir o aterrizar conocimiento
        aplicado en contexto productivo real.
      </p>
      <div class="grid grid-2 mt-3">
        <div class="card card-accent">
          <div class="card-title">Universidades y centros</div>
          <div class="card-body">
            Validación en campo, experimentación aplicada y transferencia sobre
            problemas agronómicos concretos.
          </div>
        </div>
        <div class="card card-accent-brown">
          <div class="card-title">Proyectos de innovación agraria</div>
          <div class="card-body">
            Alianzas orientadas a adopción real, replicabilidad y pequeña
            escala.
          </div>
        </div>
        <div class="card card-accent">
          <div class="card-title">Aliados tecnológicos</div>
          <div class="card-body">
            Sensorización, modelado agronómico, gemelo digital y apoyo a la
            decisión con validación en campo.
          </div>
        </div>
        <div class="card card-accent-brown">
          <div class="card-title">Administraciones y territorio</div>
          <div class="card-body">
            Iniciativas interesadas en resiliencia agraria, acceso tecnológico
            y transferencia territorial.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Formas de colaborar</h2>
      <div class="grid grid-2 mt-3">
        <div class="card card-accent">
          <div class="card-title">Pilotos de validación en campo</div>
          <div class="card-body">
            Ensayos de sensores, modelos y criterios de recomendación en
            entorno productivo real.
          </div>
        </div>
        <div class="card card-accent-brown">
          <div class="card-title">Proyectos I+D+i con transferencia</div>
          <div class="card-body">
            Metodologías, documentación y aprendizajes para replicar soluciones
            útiles fuera del proyecto.
          </div>
        </div>
        <div class="card card-accent">
          <div class="card-title">Desarrollo de producto</div>
          <div class="card-body">
            Evolución de herramientas desde pruebas técnicas a uso operativo con
            usuarios reales.
          </div>
        </div>
        <div class="card card-accent-brown">
          <div class="card-title">Transferencia territorial</div>
          <div class="card-body">
            Adaptación de conocimiento y herramientas para pequeñas
            explotaciones en distintos contextos.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Qué ofrece Viriato como entorno</h2>
      <p class="mt-2">
        Contexto real, infraestructura de validación y una capa de producto en
        la que el aprendizaje se convierte en decisiones operativas.
      </p>
      <p>
        Si trabajas en investigación agraria, gestionas una explotación o
        representas a una institución, nos interesa conocer qué problema
        quieres validar o transferir.
      </p>
      <div class="btn-group">
        <a href="mailto:viriatocooperativa@gmail.com" class="btn btn-primary">Contactar</a>
        <a href={`${base}living-lab/`} class="btn btn-secondary">Ver Living Lab</a>
      </div>
    </div>
  </section>
</BaseLayout>
