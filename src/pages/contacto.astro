---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Viriato - Contacto" description="Contacta con Viriato Cooperativa.">
  <section class="hero-page">
    <div class="container">
      <div class="eyebrow">Contacto</div>
      <h1>Hablemos</h1>
      <p class="subtitle">
        Si quieres conocer el proyecto, explorar el living lab o evaluar
        MindFarm para tu contexto, estaremos encantados de conversar.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2">
        <div class="card">
          <div class="card-title">viriatocooperativa@gmail.com</div>
          <div class="card-body">
            Si esto conecta con tu trabajo, tu finca o tu institución,
            escríbenos.
          </div>
          <div class="mt-3">
            <a href="mailto:viriatocooperativa@gmail.com" class="btn btn-primary">
              Enviar correo
            </a>
          </div>
        </div>
        <div class="card card-accent-brown">
          <div class="card-label">Dónde estamos</div>
          <div class="card-body">
            <p>Sierra de Gata, Cáceres</p>
            <p>Padul, Granada</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <div class="btn-group" style="justify-content:center;">
        <a href={`${base}`} class="btn btn-secondary">Inicio</a>
        <a href={`${base}mindfarm/`} class="btn btn-secondary">MindFarm</a>
      </div>
    </div>
  </section>
</BaseLayout>
